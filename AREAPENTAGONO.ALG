Algoritmo "AreaPentagono"
// Disciplina  : (Lógica de Programaçăo com visualg)
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Solicita o valor do lado de um pentágono multiplica por 5 para ter o perímetro, solicita a apótema e calcula a área do pentágono
// Autor(a)    : Italo Moreno
// Data atual  : 27/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
   lado: real
   perimetro: real
   apotema: real
   area: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Digite o valor do lado de um pentágono: ")
   leia(lado)
   perimetro <- lado * 5
   escreva("Digite o valor da apótema: ")
   leia(apotema)
   area <- (perimetro * apotema) / 2
   escreva("O valor da área do pentagono é: ",area,"cm˛")

Fimalgoritmo