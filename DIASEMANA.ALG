Algoritmo "DiaSemana"
// Disciplina  : Lógica de programaçăo com visualg
// Professor   : Jailson Costa dos Santos
// Descriçăo   : Digite um número de 1 a 7 e o algoritmo retorna o nome do dia da semana
// Autor(a)    : Italo Moreno
// Data atual  : 30/03/2026
Var
   // Seçăo de Declaraçőes das variáveis
   dia: inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Digite um número de 1 a 7: ")
   leia(dia)
   se dia = 1 entao
      escreva("É Domingo!")
   senao
      se dia = 2 entao
         escreva("É Segunda!")
      senao
         se dia = 3 entao
            escreva("É Terça!")
         senao
            se dia = 4 entao
               escreva("É Quarta!")
            senao
               se dia = 5 entao
                  escreva("É Quinta!")
               senao
                  se dia = 6 entao
                     escreva("É Sexta!")
                  senao
                     se dia = 7 entao
                        escreva("É Sabado!")
                     senao
                        escreva("Năo existe além de 7 dias na semana!")
                     fimse
                  fimse
               fimse
            fimse
         fimse
      fimse
   fimse
Fimalgoritmo